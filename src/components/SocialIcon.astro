---
import type { SocialIcon } from '../data/site';

interface Props {
  icon: SocialIcon;
}

const { icon } = Astro.props;
const svgProps = {
  viewBox: '0 0 24 24',
  width: '24',
  height: '24',
  'aria-hidden': 'true',
};
---

{
  icon === 'email' && (
    <svg {...svgProps} fill="none" stroke="currentColor" stroke-width="1.6">
      <rect x="2.5" y="4.5" width="19" height="15" />
      <path d="m3 6 9 7 9-7" />
    </svg>
  )
}
{
  icon === 'linkedin' && (
    <svg {...svgProps} fill="currentColor">
      <path d="M5.3 7.7H2.1V21h3.2V7.7ZM3.7 2A1.9 1.9 0 1 0 3.7 5.8 1.9 1.9 0 0 0 3.7 2ZM21.9 13.4c0-4-2.1-5.9-4.9-5.9-2.3 0-3.3 1.2-3.8 2.1V7.7H10V21h3.2v-6.6c0-1.7.3-3.4 2.5-3.4 2.2 0 2.2 2 2.2 3.5V21h3.2l.8-7.6Z" />
    </svg>
  )
}
{
  icon === 'github' && (
    <svg {...svgProps} fill="currentColor">
      <path d="M12 2a10 10 0 0 0-3.2 19.5v-2.1c-2.7.6-3.3-1.1-3.3-1.1-.4-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 0 1.5 1 1.5 1 .9 1.5 2.3 1.1 2.8.8.1-.6.4-1.1.6-1.3-2.1-.2-4.4-1.1-4.4-4.9 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.8 1A9.7 9.7 0 0 1 12 7c.9 0 1.7.1 2.5.3 2-1.3 2.8-1 2.8-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.8-2.3 4.7-4.5 4.9.4.3.7.9.7 1.8v3A10 10 0 0 0 12 2Z" />
    </svg>
  )
}
{
  icon === 'medium' && (
    <svg {...svgProps} fill="currentColor">
      <path d="M2 6.3a1 1 0 0 0-.4-.9L.5 4.6V4.3h7.2l5.6 12.2 4.9-12.2H25v.3l-.9.7a.7.7 0 0 0-.3.8v11.8a.7.7 0 0 0 .3.8l.9.7v.3h-9.2v-.3l.9-.7c.1-.1.1-.2.1-.4V6.7l-5.4 13H11L4.7 6v10.3c0 .5.2 1 .6 1.4l1.2 1.5v.3H.3v-.3l1.2-1.5c.4-.4.5-.9.5-1.4v-10Z" transform="scale(.92) translate(.8 .8)" />
    </svg>
  )
}
{
  icon === 'x' && (
    <svg {...svgProps} fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M4 3h4.2L20 21h-4.2L4 3Z" />
      <path d="M19.5 3 4.5 21" />
    </svg>
  )
}
{
  icon === 'leetcode' && (
    <svg {...svgProps} fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="m15.5 3-8 8a4 4 0 0 0 0 5.7l2.1 2.1a4 4 0 0 0 5.7 0l2.2-2.2" />
      <path d="M8.5 12.5h11" />
      <path d="m12 2-5.7 5.7" />
    </svg>
  )
}
